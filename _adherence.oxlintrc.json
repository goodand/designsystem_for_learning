{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/animation/**",
              "components/core/**",
              "components/forms/**",
              "components/layout/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard Variable|JetBrains Mono Variable|KaTeX_Main|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Pretendard Variable, JetBrains Mono Variable, KaTeX_Main, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, size, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|neutral|danger|success|warning|info|topic-1|topic-2|topic-3|topic-4|topic-5)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'neutral' | 'danger' | 'success' | 'warning' | 'info' | 'topic-1' | 'topic-2' | 'topic-3' | 'topic-4' | 'topic-5'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|disabled|fullWidth|loading|size|tone|type|variant|onClick|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, disabled, fullWidth, loading, size, tone, type, variant, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|neutral|danger)$/]",
        "message": "<Button> tone must be one of 'brand' | 'neutral' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'solid' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|outline|padding|className|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, outline, padding, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|brand)$/]",
        "message": "<Card> tone must be one of 'neutral' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|tone|className|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, onChange, disabled, tone, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|neutral)$/]",
        "message": "<Checkbox> tone must be one of 'brand' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrameBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:slots|states|onSelect|size|className|key|ref|className|style|children)$/]",
        "message": "<FrameBar> doesn't accept that prop. Declared props: slots, states, onSelect, size, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrameBar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<FrameBar> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Heading'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|level|style|className|key|ref|className|style|children)$/]",
        "message": "<Heading> doesn't accept that prop. Declared props: children, level, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SceneInfo'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|steps|id|key|ref|className|style|children)$/]",
        "message": "<SceneInfo> doesn't accept that prop. Declared props: label, steps, id."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|value|onChange|placeholder|disabled|required|fullWidth|className|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, value, onChange, placeholder, disabled, required, fullWidth, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stack'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|direction|gap|align|justify|wrap|style|className|key|ref|className|style|children)$/]",
        "message": "<Stack> doesn't accept that prop. Declared props: children, direction, gap, align, justify, wrap, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stack'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:vertical|horizontal)$/]",
        "message": "<Stack> direction must be one of 'vertical' | 'horizontal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stack'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:start|center|end|stretch)$/]",
        "message": "<Stack> align must be one of 'start' | 'center' | 'end' | 'stretch'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stack'] > JSXAttribute[name.name='justify'] > Literal[value!=/^(?:start|center|end|space-between)$/]",
        "message": "<Stack> justify must be one of 'start' | 'center' | 'end' | 'space-between'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|onRemove|href|className|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone, onRemove, href, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|neutral|danger|success|warning|info|topic-1|topic-2|topic-3|topic-4|topic-5)$/]",
        "message": "<Tag> tone must be one of 'brand' | 'neutral' | 'danger' | 'success' | 'warning' | 'info' | 'topic-1' | 'topic-2' | 'topic-3' | 'topic-4' | 'topic-5'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Text'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|weight|as|color|style|className|key|ref|className|style|children)$/]",
        "message": "<Text> doesn't accept that prop. Declared props: children, size, weight, as, color, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Text'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Text> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Text'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:normal|medium|semibold|bold)$/]",
        "message": "<Text> weight must be one of 'normal' | 'medium' | 'semibold' | 'bold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Text'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:p|span|div)$/]",
        "message": "<Text> as must be one of 'p' | 'span' | 'div'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|disabled|readOnly|invalid|required|helperText|errorMessage|fullWidth|className|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: label, placeholder, value, onChange, disabled, readOnly, invalid, required, helperText, errorMessage, fullWidth, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "note": "Full token inventory and per-token kinds are compiled from tokens/*.css — see _ds_manifest.json and tokens/ for the authoritative list."
  }
}
